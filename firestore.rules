rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Fungsi pembantu ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isPrivileged() {
      // HRD / Manager / SuperAdmin — baca dari users/{uid}.role
      // Cek exists() lebih dulu agar tidak error jika dokumen belum ada
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['hrd', 'manager', 'superadmin', 'super-admin'];
    }

    // Cek apakah request membuat dokumen yang mengandung uid milik sendiri
    // Mendukung berbagai nama field ownership
    function isOwnCreate() {
      return isSignedIn() && (
        request.resource.data.get('uid',        null) == request.auth.uid ||
        request.resource.data.get('userId',     null) == request.auth.uid ||
        request.resource.data.get('employeeUid',null) == request.auth.uid
      );
    }

    // Cek apakah dokumen yang sudah ada milik user sendiri
    function isOwnDoc() {
      return isSignedIn() && (
        resource.data.get('uid',        null) == request.auth.uid ||
        resource.data.get('userId',     null) == request.auth.uid ||
        resource.data.get('employeeUid',null) == request.auth.uid
      );
    }


    // ── users/{uid} ──────────────────────────────────────────────────────────
    match /users/{uid} {
      // User baca/tulis dokumen sendiri
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      // Siapapun yang login boleh GET dokumen user lain
      // (dibutuhkan isPrivileged() untuk membaca role orang lain)
      allow get: if isSignedIn();
    }


    // ── employee_profiles/{uid} ───────────────────────────────────────────────
    match /employee_profiles/{uid} {
      // Karyawan bisa baca profil sendiri
      allow read: if isSignedIn() && request.auth.uid == uid;
      // HRD/Admin bisa baca+tulis semua profil
      allow read, write: if isPrivileged();
    }


    // ── attendance_sites ─────────────────────────────────────────────────────
    match /attendance_sites/{siteId} {
      // Semua user yang login boleh baca lokasi kantor (diperlukan validasi jarak)
      allow read: if isSignedIn();
      // Hanya HRD/Admin yang boleh tulis
      allow write: if isPrivileged();
    }


    // ── attendance_events ─────────────────────────────────────────────────────
    match /attendance_events/{eventId} {
      // Buat record absen: harus milik sendiri (uid / userId / employeeUid)
      allow create: if isOwnCreate();

      // Baca dokumen tunggal: milik sendiri atau HRD/Admin
      allow get: if isSignedIn() && (isOwnDoc() || isPrivileged());

      // List/query: karyawan hanya boleh query with where("uid","==",auth.uid)
      // Rules Firestore akan verifikasi tiap dokumen → isOwnDoc() menjamin
      // query tidak bocor ke data orang lain
      allow list: if isSignedIn() && (isOwnDoc() || isPrivileged());

      // Hanya HRD/Admin yang boleh update/delete
      allow update, delete: if isPrivileged();
    }


    // ── passkeys/{credentialId} ───────────────────────────────────────────────
    // Collection global (top-level) untuk Login Cepat / Passkey WebAuthn.
    // Tulis hanya via Firebase Admin SDK (API route server-side) → admin bypass rules.
    // Client hanya perlu READ untuk mengecek apakah sudah punya passkey aktif.
    //
    // Query client: collection('passkeys').where('uid','==',uid).where('isActive','==',true)
    // → Firestore evaluasi resource.data.uid per dokumen, rule terpenuhi karena
    //   query sudah membatasi uid == request.auth.uid.
    match /passkeys/{credentialId} {
      allow get:  if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }


    // ── passkey_challenges/{id} ───────────────────────────────────────────────
    // Challenge sementara WebAuthn — hanya diakses oleh API routes (Admin SDK).
    match /passkey_challenges/{id} {
      allow read, write: if false;
    }


    // ── Koleksi pendukung HRP ─────────────────────────────────────────────────
    match /profiles/{uid} {
      allow read: if isSignedIn();
    }

    match /brands/{brandId} {
      allow read: if isSignedIn();
    }

    match /companies/{companyId} {
      allow read: if isSignedIn();
    }

    match /work_locations/{locId} {
      allow read: if isSignedIn();
    }


    // ── attendance_condition_reports ─────────────────────────────────────────
    match /attendance_condition_reports/{reportId} {
      // Staff: create laporan milik sendiri (uid + employeeUid harus sama dengan auth.uid)
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.employeeUid == request.auth.uid;

      // Staff: baca laporan milik sendiri
      allow get, list: if isSignedIn() && (isOwnDoc() || isPrivileged());

      // HRD: boleh update hanya field review (reviewStatus, reviewNote, reviewedAt, reviewedByUid)
      // Staff: tidak boleh mengubah field review
      allow update: if isPrivileged()
        || (isOwnDoc() && isSignedIn()
            && !("reviewStatus"  in request.resource.data.diff(resource.data).affectedKeys())
            && !("reviewNote"    in request.resource.data.diff(resource.data).affectedKeys())
            && !("reviewedAt"    in request.resource.data.diff(resource.data).affectedKeys())
            && !("reviewedByUid" in request.resource.data.diff(resource.data).affectedKeys()));

      allow delete: if isPrivileged();
    }


    // ── Push Notification Tokens ─────────────────────────────────────────────
    match /attendance_notification_tokens/{tokenId} {
      // User boleh create/read/update token miliknya sendiri
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update: if isSignedIn() && resource.data.uid == request.auth.uid;
      // HRD/Admin bisa baca semua untuk monitoring
      allow list, read: if isPrivileged();
    }

    // ── Push Notification Logs ───────────────────────────────────────────────
    match /attendance_notification_logs/{logId} {
      // Log dibuat server-side; user hanya bisa baca log miliknya
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if isPrivileged();
    }

    // ── Fallback: HRD/Admin baca semua ───────────────────────────────────────
    // Hanya berlaku untuk path yang belum punya rule spesifik di atas
    match /{path=**} {
      allow read: if isPrivileged();
    }
  }
}
