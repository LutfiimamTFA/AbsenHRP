rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Site Configurations (Gedung A/B)
    match /attendance_sites/{siteId} {
      allow read: if isSignedIn();
    }

    // User Profiles & Brands
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }
    
    match /profiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    match /brands/{brandId} {
      allow read: if isSignedIn();
    }

    // Attendance Events
    match /attendance_events/{eventId} {
      allow list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
