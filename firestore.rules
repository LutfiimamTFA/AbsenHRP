rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isInternal() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // User Profile
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)));
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Lokasi Kantor: Dibaca oleh semua user internal untuk geofencing
    match /work_locations/{locationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && 
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
         exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)));
    }

    // Kejadian Absensi: HANYA boleh baca milik sendiri (kecuali Admin/HRD)
    match /attendance_events/{eventId} {
      allow get, list: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid))
      );
      // Penulisan hanya melalui Cloud Function yang aman
      allow write: if false;
    }
  }
}
