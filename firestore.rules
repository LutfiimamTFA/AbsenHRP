rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isHrd() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid));
    }
    
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Recruitment Rules (Preserved)
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isHrd() || isSuperAdmin();
    }
    match /applications/{appId} {
      allow create: if true;
      allow read, update: if isHrd() || isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /assessments/{assessmentId} {
      allow read, write: if isHrd() || isSuperAdmin();
    }

    // Konfigurasi Absensi (HRP Managed)
    match /attendance_config/{configId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if isHrd() || isSuperAdmin();
    }

    // Profil User
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isHrd() || isSuperAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Role Markers (Private)
    match /roles_admin/{uid} { allow read, write: if false; }
    match /roles_hrd/{uid} { allow read, write: if false; }
    match /roles_manager/{uid} { allow read, write: if false; }

    // Kejadian Absensi
    match /attendance_events/{eventId} {
      // Izinkan pencarian riwayat milik sendiri
      // Diperbaiki untuk menangani filter query uid sebagai list
      allow list: if isSignedIn() && (
        isHrd() || 
        isSuperAdmin() || 
        (request.query.filters.uid == [request.auth.uid])
      );
      
      // Akses detail dokumen
      allow get: if isSignedIn() && (isHrd() || isSuperAdmin() || resource.data.uid == request.auth.uid);
      
      // User boleh membuat absen miliknya sendiri
      allow create: if isSignedIn() 
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.tsServer == request.time;
        
      allow update, delete: if false;
    }

    // Work Locations (Legacy support)
    match /work_locations/{id} {
      allow read: if isSignedIn();
      allow write: if isHrd() || isSuperAdmin();
    }
  }
}