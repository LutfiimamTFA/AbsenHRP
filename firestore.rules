
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Role markers (Managed via Admin/HRP)
    match /roles_admin/{uid} { allow read: if isSignedIn(); }
    match /roles_hrd/{uid} { allow read: if isSignedIn(); }

    // Users & Profiles
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }
    
    match /profiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // Attendance Configuration (Sites Gedung A/B)
    match /attendance_sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // Attendance Events
    match /attendance_events/{eventId} {
      allow list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Brands (Support for useUser hook)
    match /brands/{brandId} {
      allow read: if isSignedIn();
    }
  }
}
