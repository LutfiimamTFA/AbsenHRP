rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Role resolution helpers using marker collections
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isHrd() {
      return exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid));
    }

    // User profiles: Users can read/write their own; Admins/HRD can read all.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin() || isHrd());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Role markers: Accessible to the owner for role resolution fallbacks
    match /roles_admin/{uid} { allow read: if isSignedIn() && request.auth.uid == uid; }
    match /roles_hrd/{uid} { allow read: if isSignedIn() && request.auth.uid == uid; }
    match /roles_manager/{uid} { allow read: if isSignedIn() && request.auth.uid == uid; }

    // ABSEN FIX (MATCH EXACT COLLECTION NAMES FROM ERROR)
    match /work_locations/{locationId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
         exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)));
    }

    match /attendance_events/{eventId} {
      allow get, list: if request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) ||
        resource.data.uid == request.auth.uid
      );
      allow create, update, delete: if false;
    }
  }
}