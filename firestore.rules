rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user has a privileged role
    // Uses safer property access with .get() to prevent evaluation errors
    function isPrivileged() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') in ['hrd', 'manager', 'superadmin']) ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid))
      );
    }

    // User profiles
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isPrivileged());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Role fallbacks
    match /roles_admin/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }
    match /roles_hrd/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }
    match /roles_manager/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Attendance Events
    match /attendance_events/{event} {
      // Admins can list all, users can only list their own (requires query filter)
      // Admins can get any, users can only get their own
      allow read: if request.auth != null && (
        isPrivileged() || 
        (resource != null && resource.data.uid == request.auth.uid)
      );
      
      // Writes are handled by the Cloud Function (submitAttendance) which uses Admin SDK
      allow write: if false;
    }

    // Work Locations
    match /work_locations/{loc} {
      // All authenticated users can list work locations for geofencing
      allow get, list: if request.auth != null;
      // Only privileged users can manage locations
      allow write: if isPrivileged();
    }
  }
}