
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Konfigurasi Absensi (HRP Managed)
    match /attendance_config/{configId} {
      allow get: if request.auth != null;
      allow list, write: if false; // Hanya diubah via admin portal / HRP
    }

    // Profil User
    match /users/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid))
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Role Markers (Private)
    match /roles_admin/{uid} { allow read, write: if false; }
    match /roles_hrd/{uid} { allow read, write: if false; }
    match /roles_manager/{uid} { allow read, write: if false; }

    // Kejadian Absensi
    match /attendance_events/{eventId} {
      allow get: if request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) ||
        resource.data.uid == request.auth.uid
      );
      allow list: if request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) ||
        (request.query.limit <= 100 && request.query.filters.uid == request.auth.uid)
      );
      allow write: if false; // Melalui Cloud Function submitAttendance
    }
  }
}
