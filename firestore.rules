rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Role resolution helpers using marker collections
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isHrd() {
      return exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid));
    }

    function isManager() {
      return exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid));
    }

    // Check role in user profile document
    function hasPrivilegedRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) && get(path).data.role in ['hrd', 'manager', 'superadmin', 'super-admin'];
    }

    // Combined privileged check
    function isPrivileged() {
      return isSignedIn() && (isAdmin() || isHrd() || isManager() || hasPrivilegedRole());
    }

    // User profiles: Users can read/write their own; Admins can read all.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isPrivileged());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Role markers: Accessible to the owner for role resolution fallbacks
    match /roles_admin/{uid} { allow read: if isSignedIn() && request.auth.uid == uid; }
    match /roles_hrd/{uid} { allow read: if isSignedIn() && request.auth.uid == uid; }
    match /roles_manager/{uid} { allow read: if isSignedIn() && request.auth.uid == uid; }

    // Attendance Events: 
    // - Employees can only read their own (requires query filter where('uid', '==', auth.uid))
    // - Privileged roles (Admin/HRD/Manager) can read all.
    match /attendance_events/{event} {
      allow read: if isSignedIn() && (
        isPrivileged() || 
        (resource.data.uid == request.auth.uid)
      );
      allow write: if false;
    }

    // Work Locations: All authenticated users can read for geofencing. Only privileged can manage.
    match /work_locations/{loc} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }
  }
}