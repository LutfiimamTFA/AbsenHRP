rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Minimal and robust privilege check following HRP pattern
    function isPrivileged() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') in ['hrd', 'manager', 'superadmin'])
      );
    }

    // User profiles: Users can read/write their own; Admins can read all.
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isPrivileged());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Role markers: Accessible to the owner for role resolution fallbacks
    match /roles_admin/{uid} { allow read: if request.auth != null && request.auth.uid == uid; }
    match /roles_hrd/{uid} { allow read: if request.auth != null && request.auth.uid == uid; }
    match /roles_manager/{uid} { allow read: if request.auth != null && request.auth.uid == uid; }

    // Attendance Events: 
    // - Employees can only read their own (requires query filter where('uid', '==', auth.uid))
    // - Privileged roles (Admin/HRD/Manager) can read all.
    // - All client-side writes are denied; handled by secure Cloud Functions.
    match /attendance_events/{event} {
      allow read: if request.auth != null && (
        isPrivileged() || 
        resource.data.uid == request.auth.uid
      );
      allow write: if false;
    }

    // Work Locations: All authenticated users can read for geofencing. Only privileged can manage.
    match /work_locations/{loc} {
      allow read: if request.auth != null;
      allow write: if isPrivileged();
    }
  }
}