rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fungsi pembantu umum
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isStaff() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['hrd', 'manager', 'superadmin', 'super-admin'];
    }

    // Koleksi Profil User
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow get: if isSignedIn();
    }
    
    // Koleksi Lokasi Kantor (Site A/B)
    match /attendance_sites/{siteId} {
      // Izinkan baca (get & list) untuk semua user agar site resolver jalan
      allow read: if isSignedIn();
    }
    
    // Koleksi Event Absensi
    match /attendance_events/{eventId} {
      // User hanya bisa membuat data milik sendiri
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      
      // Izin baca dipisah agar kegagalan evaluasi isStaff() tidak memblokir pemilik data
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow read: if isStaff();
    }

    // Pendukung HRP
    match /profiles/{uid} {
      allow read: if isSignedIn();
    }
    
    match /brands/{brandId} {
      allow read: if isSignedIn();
    }
    
    // Fallback untuk akses admin HRP ke koleksi lain
    match /{path=**} {
      allow read: if isStaff();
    }
  }
}