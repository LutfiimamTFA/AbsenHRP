
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "karyawan", "hrd", "manager", "superadmin"] },
        "primaryDeviceId": { "type": "string" },
        "brandName": { "type": "string" },
        "division": { "type": "string" }
      }
    },
    "AttendanceConfig": {
      "title": "Attendance Configuration",
      "description": "Global settings for office geofencing and shifts, managed by HRP.",
      "type": "object",
      "properties": {
        "office": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "radiusM": { "type": "number" }
          }
        },
        "shift": {
          "type": "object",
          "properties": {
            "startTime": { "type": "string" },
            "endTime": { "type": "string" },
            "graceLateMinutes": { "type": "number" },
            "timezone": { "type": "string" }
          }
        }
      }
    },
    "AttendanceEvent": {
      "title": "Attendance Event",
      "description": "Records of clock-in and clock-out events.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "mode": { "type": "string", "enum": ["ONSITE", "OFFSITE"] },
        "tsServer": { "type": "string", "format": "date-time" },
        "tsClient": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "accuracyM": { "type": "number" },
        "deviceId": { "type": "string" },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Primary user profiles and roles."
    },
    "/attendance_config/{configId}": {
      "schema": { "$ref": "#/entities/AttendanceConfig" },
      "description": "Global attendance settings (office & shift)."
    },
    "/attendance_events/{eventId}": {
      "schema": { "$ref": "#/entities/AttendanceEvent" },
      "description": "Clock events."
    }
  }
}
